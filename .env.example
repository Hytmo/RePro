# ---- Required for the app (already set on Netlify) ----
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key
# Public site URL, used for sitemap/robots/Stripe redirects
NEXT_PUBLIC_SITE_URL=https://repro-lu.netlify.app
# Google Maps (optional). If unset, the map falls back to OpenStreetMap.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---- Supabase Edge Function secrets (set with: supabase secrets set, or dashboard) ----
# Stripe (monetization). Webhook secret from the Stripe webhook you create pointing at the stripe-webhook function URL.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# AI review summaries
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # optional override
# Transactional email for enquiries
# RESEND_API_KEY=re_...
# LEAD_FROM_EMAIL=RePro <noreply@yourdomain>
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are injected into edge functions automatically.
